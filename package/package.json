{
  "name": "@gfazioli/mantine-select-stepper",
  "version": "3.0.0",
  "description": "Mantine SelectStepper is a React component for cycling through options via stepper buttons. Supports keyboard navigation, infinite looping, swipe gestures, vertical orientation, responsive props, imperative API, disabled items, smooth animations, and full Mantine Styles API integration.",
  "homepage": "https://gfazioli.github.io/mantine-select-stepper/",
  "packageManager": "yarn@4.0.1",
  "license": "MIT",
  "author": "Giovambattista Fazioli <giovambattista.fazioli@gmail.com>",
  "keywords": [
    "select-stepper",
    "mantine",
    "mantine-ui",
    "react",
    "reactjs",
    "reactjs-components",
    "typescript",
    "component",
    "nextjs",
    "stepper",
    "select",
    "swipe",
    "responsive",
    "animation",
    "keyboard-navigation",
    "accessible",
    "styles-api",
    "form"
  ],
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./styles.layer.css": "./dist/styles.layer.css"
  },
  "repository": "https://github.com/gfazioli/mantine-select-stepper.git",
  "peerDependencies": {
    "@mantine/core": ">=7.0.0",
    "@mantine/hooks": ">=7.0.0",
    "@tabler/icons-react": "^3.34.0",
    "react": "^18.x || ^19.x",
    "react-dom": "^18.x || ^19.x"
  },
  "bugs": "https://github.com/gfazioli/mantine-select-stepper/issues"
}
